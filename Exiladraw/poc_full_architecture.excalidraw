   "boundElements": [],
   "updated": 1,
   "link": null,
   "locked": false,
   "text": "Legend:  green = cheap model (haiku tier) \u00b7 orange = capable model (sonnet tier) \u00b7 yellow = no-LLM optimization \u00b7 gray = PostgreSQL \u00b7 red = external service \u00b7 purple = UI/entry \u00b7 teal = RAG \u00b7 dashed = optional/async path",
   "fontSize": 15,
   "fontFamily": 1,
   "textAlign": "left",
   "verticalAlign": "top",
   "containerId": null,
   "originalText": "Legend:  green = cheap model (haiku tier) \u00b7 orange = capable model (sonnet tier) \u00b7 yellow = no-LLM optimization \u00b7 gray = PostgreSQL \u00b7 red = external service \u00b7 purple = UI/entry \u00b7 teal = RAG \u00b7 dashed = optional/async path",
   "lineHeight": 1.25,
   "baseline": 14.75
