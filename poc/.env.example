# Get a free API key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# PostgreSQL connection string
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/stackforge

# Pinecone vector search (https://app.pinecone.io → API Keys)
# Leave blank to fall back to BM25-only retrieval.
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=stackforge-poc
# Optional: override region (default aws/us-east-1)
# PINECONE_CLOUD=aws
# PINECONE_REGION=us-east-1

# --- Production swap (uncomment to use Anthropic instead of Groq) ---
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# LLM_BASE_URL=https://api.anthropic.com/v1
# MODEL_CHEAP=claude-haiku-4-5-20251001
# MODEL_CAPABLE=claude-sonnet-4-6
